# Код на карточке / зале (один на всех гостей)
EVENT_PIN=2026

# --- Браузер (Vite): префикс VITE_ обязателен; попадает в клиентский бандл ---
# Project Settings → API: Project URL и Publishable key (или legacy anon)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Сервер (Express): без префикса, только в .env на хосте, не в Git ---
SUPABASE_URL=https://xxxx.supabase.co
# Только JWT секрет "service_role" (eyJ...). НЕ publishable (sb_publishable_...) — он только для VITE_
SUPABASE_SERVICE_ROLE_KEY=

# Имя bucket в Storage (создайте в Dashboard или см. supabase/schema.sql)
SUPABASE_BUCKET=wedding-photos

# Порт API + раздача фронта в production (после npm run build)
PORT=8787

# Максимальный размер одного файла (МБ)
MAX_FILE_MB=40
